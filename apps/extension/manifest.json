{
  "manifest_version": 3,
  "name": "Study Inbox Local Fixture",
  "version": "0.2.0",
  "description": "Milestone 2A local-only conversation capture demonstration.",
  "permissions": ["storage"],
  "host_permissions": [
    "http://127.0.0.1:4173/*",
    "http://127.0.0.1:8765/*"
  ],
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://127.0.0.1:4173/*"],
      "js": ["content/index.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Study Inbox",
    "default_popup": "popup/index.html"
  }
}
