{
  "manifest_version": 3,
  "name": "Study Inbox",
  "version": "0.2.0",
  "description": "Local fixture capture and an opt-in minimal DeepSeek conversation adapter.",
  "permissions": ["storage", "scripting", "alarms"],
  "host_permissions": [
    "http://127.0.0.1:4173/*",
    "http://127.0.0.1:8765/*"
  ],
  "optional_host_permissions": [
    "https://chat.deepseek.com/*",
    "https://www.doubao.com/*"
  ],
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://127.0.0.1:4173/*"],
      "js": ["content/index.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Study Inbox",
    "default_popup": "popup/index.html"
  }
}
